# ─── Environment variables ────────────────────────────────────
# Contains API URLs and any frontend secrets
.env
.env.local
.env.development.local
.env.test.local
.env.production.local

# ─── Dependencies ─────────────────────────────────────────────
node_modules/

# ─── Build output ─────────────────────────────────────────────
