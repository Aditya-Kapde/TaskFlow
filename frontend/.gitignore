build/
dist/

# ─── Logs ─────────────────────────────────────────────────────
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# ─── OS generated files ───────────────────────────────────────
.DS_Store
.DS_Store?
Thumbs.db
desktop.ini

# ─── Editor / IDE files ───────────────────────────────────────
.vscode/
.idea/
*.suo
*.ntvs*
*.njsproj
*.sln

# ─── Testing ──────────────────────────────────────────────────
coverage/

# ─── Optional cache files ─────────────────────────────────────
.cache/
.parcel-cache/