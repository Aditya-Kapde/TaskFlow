# ─── Environment variables ────────────────────────────────────
# Contains secrets: JWT keys, MongoDB URI, etc.
# Never commit this under any circumstances
.env
.env.local
.env.production
.env.staging

# ─── Dependencies ─────────────────────────────────────────────
# Installed by npm install — never commit node_modules
node_modules/

# ─── Logs ─────────────────────────────────────────────────────
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# ─── OS generated files ───────────────────────────────────────
.DS_Store
.DS_Store?
Thumbs.db
desktop.ini

# ─── Editor / IDE files ───────────────────────────────────────
.vscode/
.idea/
*.suo
*.ntvs*
*.njsproj
*.sln

# ─── Build output ─────────────────────────────────────────────
dist/
build/

# ─── Coverage reports ─────────────────────────────────────────
coverage/